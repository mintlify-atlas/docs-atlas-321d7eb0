  "keyFeatures": [
    "Automatic Python version resolution from .python-version, runtime.txt, or Pipfile.lock",
    "Support for pip, Pipenv, Poetry, and uv package managers",
    "Build cache with automatic invalidation on Python version, stack, or package manager changes",
    "Django collectstatic automatic execution during build",
    "NLTK corpus downloader via nltk.txt",
    "Pre/post compile build hooks (bin/pre_compile and bin/post_compile)",
    "Automatic WEB_CONCURRENCY configuration for Gunicorn",
    "Supported stacks: heroku-22, heroku-24"
  ],
  "publicApiSurface": [
    "bin/compile <build-dir> <cache-dir> <env-dir>",
    "bin/detect <build-dir>",
    "bin/release <build-dir>",
    "bin/report <build-dir> <cache-dir> <env-dir>",
    ".python-version file",
